# Example environment variables
# Copy this to .env and fill in your values

# Indeed Scraper Configuration
INDEED_BASE_URL=https://www.indeed.com
SEARCH_QUERIES=python developer;data engineer;machine learning
LOCATIONS=Remote;New York, NY;San Francisco, CA
SCHEDULE_INTERVAL_HOURS=1
LOG_LEVEL=INFO

# Database (PostgreSQL primary)
DB_TYPE=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=indeed_scraper
POSTGRES_USER=scraper
POSTGRES_PASSWORD=your_secure_password_here

# MongoDB (alternative)
# DB_TYPE=mongodb
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB=indeed_scraper

# Proxy Providers
# ProxyMesh
PROXYMESH_USER=your_proxymesh_user
PROXYMESH_PASS=your_proxymesh_password

# ScraperAPI
SCRAPERAPI_KEY=your_scraperapi_key

# Optional: Google Custom Search for domain resolution
# GOOGLE_SEARCH_KEY=your_google_api_key

# Monitoring
GRAFANA_PASSWORD=admin